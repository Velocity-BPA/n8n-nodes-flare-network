{
  "name": "@velocity-bpa/n8n-nodes-flare-network",
  "version": "1.0.0",
  "description": "n8n community node for Flare Network FTSO data feeds, delegation, FAssets, state connector, and network operations",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://docs.n8n.io/integrations/community-nodes/",
  "author": {
    "name": "Velocity BPA",
    "email": "support@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-flare-network.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FlareNetworkApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FlareNetwork/FlareNetwork.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "flare",
    "flare-network",
    "ftso",
    "fassets",
    "delegation",
    "state-connector",
    "blockchain"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.15.2",
    "@typescript-eslint/parser": "^7.15.2",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.1.0",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.7.4"
  }
}